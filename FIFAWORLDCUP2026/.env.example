DATABASE_URL="postgresql://user:password@127.0.0.1:5432/polymatch?schema=public"

# Canonical public site URL (no trailing slash). Used for SEO metadata,
# sitemap.xml, robots.txt and absolute links in OpenGraph/Twitter cards.
NEXT_PUBLIC_SITE_URL=""

# -------------------------------------------------------
# Authentication (NextAuth v5)
# -------------------------------------------------------
# Secret used to sign cookies/JWT. Generate one with: npx auth secret
AUTH_SECRET=""

# Public site URL in production (NextAuth uses it for OAuth callbacks).
# In development this can be omitted and NextAuth will use http://localhost:3000.
# AUTH_URL="https://world-cup-2026-predictions.com"

# Google OAuth 2.0 — Credentials from Google Cloud Console → APIs & Services
# → Credentials → OAuth 2.0 Client ID (Web application).
# Authorized Redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
